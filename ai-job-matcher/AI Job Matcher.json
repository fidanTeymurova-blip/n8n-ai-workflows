    {
      "parameters": {
        "jsCode": "const html = $input.item.json.data;\n\nif (!html || typeof html !== 'string') {\n  return [{ json: { title: 'Error', description: 'No data', url: '' } }];\n}\n\n// Title\nconst titleMatch = html.match(/<h1[^>]*>(.*?)<\\/h1>/s);\nconst title = titleMatch ? titleMatch[1].replace(/<[^>]*>/g, '').trim() : 'Unknown';\n\n// Description - vacancy__description div\nconst descMatch = html.match(/<div class=\"vacancy__description content\">([\\s\\S]*?)<\\/div>\\s*<div class=\"vacancy__info__side-bar\"/);\nconst desc = descMatch ? descMatch[1].replace(/<[^>]*>/g, ' ').replace(/\\s+/g, ' ').trim().substring(0, 2000) : '';\n\n// URL\nconst urlMatch = html.match(/<link rel=\"canonical\" href=\"([^\"]+)\"/);\nconst url = urlMatch ? urlMatch[1] : '';\n\nreturn [{ json: { title, description: desc, url } }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
