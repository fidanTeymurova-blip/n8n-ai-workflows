    {
      "parameters": {
        "jsCode": "const html = $input.first().json.data;\n\nconst regex = /href=\"(https:\\/\\/classic\\.jobsearch\\.az\\/vacancies\\/[^\"]+)\" class=\"vacancies__mobile-link\"/g;\nconst matches = [...html.matchAll(regex)];\n\nconst keywords = ['ai', 'automation'];\nconst links = [...new Set(matches.map(m => m[1]))]\n  .filter(link => keywords.some(kw => link.toLowerCase().includes(kw)));\n\nreturn links.length > 0 \n  ? links.map(link => ({ json: { url: link } }))\n  : [{ json: { error: 'No matching links' } }];"
      },
